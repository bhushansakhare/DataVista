# SPA fallback for Apache / cPanel / Plesk.
#
# When the React build is served as static files (e.g. uploaded into
# public_html), Apache must rewrite unknown URLs to index.html so React
# Router can handle routes like /s/:token, /app/*, /dashboard/*.
#
# Vite copies this file from client/public/ into client/dist/ on build.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Don't rewrite the API — let it proxy through to the Node app or 404.
  RewriteCond %{REQUEST_URI} !^/api/

  # Skip real files (assets/index.js, /favicon.svg, etc.)
  RewriteCond %{REQUEST_FILENAME} !-f
  # Skip real directories
  RewriteCond %{REQUEST_FILENAME} !-d

  # Everything else → index.html
  RewriteRule ^ index.html [L]
</IfModule>

# Long-cache hashed static assets
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|svg|png|jpg|jpeg|gif|ico|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
